# Do not derive this from LIVEKIT_URL.
LIVEKIT_SIP_HOST=your-project-id-without-p_.sip.livekit.cloud
LIVEKIT_AGENT_NAME=telephony_agent_v3

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notifications@agents.example.com

GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project"}

INTERNAL_SECRET=change-me
PLATFORM_PORT=8000
ENVIRONMENT=development
SENTRY_DSN=

# Optional local defaults
DEFAULT_TEST_NUMBER=+15555550100

