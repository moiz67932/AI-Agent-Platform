LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_AGENT_NAME=telephony_agent_v3

OPENAI_API_KEY=sk-proj-...

LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.85
LLM_MAX_TOKENS=200

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

DEMO_CLINIC_ID=your-clinic-uuid

ENVIRONMENT=development
VERSION=unknown

# Sentry error monitoring
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# Email notifications (shared secret between agent and backend)
AGENT_WEBHOOK_SECRET=generate-a-random-secret-here
# URL of the Node.js backend for notification webhooks
BACKEND_URL=http://localhost:3001
