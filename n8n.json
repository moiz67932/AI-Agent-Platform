          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get the email address from the Build Personalized Email node\nconst emailData = $('Build Personalized Email').first();\nconst recipientEmail = emailData.json.recipientEmail;\n\n// Calculate Pakistan Standard Time (UTC+5) in ISO 8601 format\nconst now = new Date();\nconst pstOffsetMs = 5 * 60 * 60 * 1000;\nconst pstDate = new Date(now.getTime() + pstOffsetMs);\n\nconst pad = (n) => n.toString().padStart(2, '0');\nconst pstISO = pstDate.getUTCFullYear() + '-' +\n  pad(pstDate.getUTCMonth() + 1) + '-' +\n  pad(pstDate.getUTCDate()) + 'T' +\n  pad(pstDate.getUTCHours()) + ':' +\n  pad(pstDate.getUTCMinutes()) + ':' +\n  pad(pstDate.getUTCSeconds()) + '+05:00';\n\nreturn [{\n  json: {\n    \"Email\": recipientEmail,\n    \"1st Email\": \"TRUE\",\n    \"Time Sent\": pstISO\n  }\n}];"
      },
